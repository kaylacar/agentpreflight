{
  "name": "speed",
  "mode": "warn-only",
  "enabledRuleSets": [
    "filesystem",
    "git",
    "secrets",
    "scope",
    "release",
    "time-estimation"
  ],
  "destructiveRequireToken": false,
  "autoPatchAllowedRules": ["force-push-protection", "platform-path-sep", "onedrive-redirect"],
  "requireCalibrationOnEstimates": false,
  "prewriteChecks": {
    "enabled": false
  }
}
