{
  "name": "enterprise",
  "mode": "enforce",
  "enabledRuleSets": [
    "filesystem",
    "git",
    "naming",
    "environment",
    "parallel",
    "network",
    "secrets",
    "scope",
    "release",
    "session",
    "prewrite",
    "time-estimation"
  ],
  "destructiveRequireToken": true,
  "autoPatchAllowedRules": ["platform-path-sep", "onedrive-redirect"],
  "requireCalibrationOnEstimates": true,
  "prewriteChecks": {
    "enabled": true,
    "maxBytes": 250000,
    "tsRequireTypeHints": true,
    "applyToExtensions": [".ts", ".tsx", ".js", ".jsx"],
    "lintCommand": "npm run lint",
    "typecheckCommand": "npm run typecheck"
  }
}
