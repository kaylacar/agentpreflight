{
  "name": "agentpreflight",
  "version": "0.1.0",
  "description": "Pre-flight validation for tool calls that catches mistakes before execution",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "agentpreflight-setup-editorial": "./setup/editorial-setup.mjs",
    "agentpreflight-setup-hooks": "./setup/hooks-setup.mjs",
    "agentpreflight-codex": "./setup/codex-preflight.mjs",
    "agentpreflight-codex-hook": "./setup/codex-pre-tool-hook.mjs",
    "agentpreflight-exec": "./setup/preflight-exec.mjs",
    "agentpreflight-state": "./setup/state.mjs",
    "agentpreflight-import": "./setup/import-state.mjs"
  },
  "files": [
    "dist",
    "setup",
    "templates",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:contracts": "node setup/verify-guardrails.mjs",
    "verify:merge-gates": "node setup/verify-merge-gates.mjs",
    "typecheck": "tsc --noEmit",
    "setup:claude": "node setup/claude-hook.mjs",
    "setup:editorial": "node setup/editorial-setup.mjs",
    "setup:hooks": "node setup/hooks-setup.mjs",
    "state:editorial": "node setup/state.mjs",
    "import:editorial": "node setup/import-state.mjs",
    "setup:openclaw": "node setup/openclaw-setup.mjs",
    "openclaw:package": "node setup/package-openclaw-app.mjs",
    "preflight:ci": "node setup/replay-ci.mjs",
    "preflight:exec": "node setup/preflight-exec.mjs",
    "preflight:overnight": "node setup/preflight-overnight.mjs",
    "preflight:report": "node setup/analyze-telemetry.mjs --file .preflight/telemetry.jsonl --output .preflight/metrics-report.md",
    "preflight:incidents": "node setup/blocked-incidents-report.mjs --file .preflight/telemetry.jsonl --output .preflight/blocked-incidents.md",
    "preflight:fp-label": "node setup/label-false-positives.mjs --file .preflight/telemetry.jsonl --output-csv .preflight/fp-review.csv --output-json .preflight/fp-summary.json"
  },
  "keywords": [
    "validation",
    "tool-calls",
    "preflight"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}

