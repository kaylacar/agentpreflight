{
  "name": "agentpreflight",
  "version": "0.1.0",
  "description": "Pre-flight validation for tool calls that catches mistakes before execution",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "setup:claude": "node setup/claude-hook.mjs",
    "preflight:ci": "node setup/replay-ci.mjs",
    "preflight:exec": "node setup/preflight-exec.mjs",
    "preflight:overnight": "node setup/preflight-overnight.mjs"
  },
  "keywords": [
    "validation",
    "tool-calls",
    "preflight"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}

